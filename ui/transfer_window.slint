import "fonts/MaterialIcons-Regular.ttf";

import { Theme } from "theme.slint";
import { SftpEntry } from "sftp_panel.slint";
import { TransferInfo } from "transfer_info.slint";
import { LocalFilePanel } from "local_file_panel.slint";
import { RemoteFilePanel } from "remote_file_panel.slint";

export struct TransferRemoteTabInfo {
    id: string,
    title: string,
    connected: bool,
}

export component TransferWindow inherits Window {
    title: @tr("File transfer");
    min-width: 880px;
    min-height: 520px;
    preferred-width: 1000px;
    preferred-height: 620px;
    background: Theme.bg-root;

    in property <string> session-title;
    in property <string> local-path;
    in property <[SftpEntry]> local-entries;
    in property <string> local-status;
    in property <string> remote-path;
    in property <[SftpEntry]> remote-entries;
    in property <string> remote-status;
    in property <bool> remote-loading;
    in property <[TransferRemoteTabInfo]> remote-tabs;
    in-out property <string> active-remote-tab-id;
    in property <[TransferInfo]> transfers;

    callback local-navigate(string);
    callback local-refresh();
    callback upload-local(string);
    callback remote-navigate(string);
    callback remote-refresh();
    callback download-remote(string);
    callback remote-tab-selected(string);
    callback remote-tab-closed(string);
    callback remote-tab-reconnect(string);
    callback clear-transfers();
    callback close-window();

    VerticalLayout {
        width: root.width;
        height: root.height;
        spacing: 0;

        Rectangle {
            height: 38px;
            background: Theme.bg-panel-alt;
            HorizontalLayout {
                padding-left: 12px;
                padding-right: 8px;
                spacing: 8px;
                Text {
                    text: root.session-title;
                    color: Theme.text-primary;
                    font-size: Theme.fs-md;
                    horizontal-stretch: 1;
                    overflow: elide;
                    vertical-alignment: center;
                }
                Rectangle {
                    width: 28px;
                    height: 26px;
                    border-radius: Theme.radius-sm;
                    background: close-ta.has-hover ? Theme.bg-hover : transparent;
                    close-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.close-window(); }
                    }
                    Text {
                        text: "\u{E5CD}";
                        font-family: "Material Icons";
                        color: Theme.text-secondary;
                        font-size: Theme.fs-md;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        HorizontalLayout {
            vertical-stretch: 1;
            spacing: 0;

            LocalFilePanel {
                horizontal-stretch: 1;
                current-path: root.local-path;
                entries: root.local-entries;
                status: root.local-status;
                navigate(path) => { root.local-navigate(path); }
                refresh() => { root.local-refresh(); }
                upload(path) => { root.upload-local(path); }
            }

            Rectangle { width: 1px; background: Theme.border-strong; }

            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 0;

                Rectangle {
                    height: 30px;
                    background: Theme.bg-panel-alt;
                    HorizontalLayout {
                        padding-left: 6px;
                        padding-right: 6px;
                        spacing: 4px;

                        for tab[i] in root.remote-tabs : Rectangle {
                            width: 168px;
                            height: 26px;
                            border-radius: Theme.radius-sm;
                            background: root.active-remote-tab-id == tab.id ? Theme.bg-active : (tab-ta.has-hover ? Theme.bg-hover : transparent);
                            tab-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.remote-tab-selected(tab.id); }
                                double-clicked => { root.remote-tab-reconnect(tab.id); }
                            }
                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 4px;
                                spacing: 5px;
                                Text {
                                    text: "\u{E2C8}";
                                    font-family: "Material Icons";
                                    color: tab.connected ? Theme.success : Theme.text-muted;
                                    font-size: Theme.fs-sm;
                                    width: 16px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: tab.title;
                                    color: Theme.text-primary;
                                    font-size: Theme.fs-sm;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                    vertical-alignment: center;
                                }
                                Rectangle {
                                    width: 20px;
                                    height: 20px;
                                    border-radius: Theme.radius-sm;
                                    background: close-tab-ta.has-hover ? Theme.bg-hover : transparent;
                                    close-tab-ta := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.remote-tab-closed(tab.id); }
                                    }
                                    Text {
                                        text: "\u{E5CD}";
                                        font-family: "Material Icons";
                                        color: Theme.text-secondary;
                                        font-size: Theme.fs-xs;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }

                RemoteFilePanel {
                    vertical-stretch: 1;
                    current-path: root.remote-path;
                    entries: root.remote-entries;
                    status: root.remote-status;
                    loading: root.remote-loading;
                    navigate(path) => { root.remote-navigate(path); }
                    refresh() => { root.remote-refresh(); }
                    download(path) => { root.download-remote(path); }
                }
            }
        }

        Rectangle { height: 1px; background: Theme.border-strong; }

        Rectangle {
            height: 132px;
            background: Theme.bg-panel-alt;
            VerticalLayout {
                padding-left: 10px;
                padding-right: 10px;
                padding-top: 6px;
                padding-bottom: 8px;
                spacing: 6px;

                HorizontalLayout {
                    height: 22px;
                    Text {
                        text: @tr("Transfers");
                        color: Theme.text-secondary;
                        font-size: Theme.fs-sm;
                        horizontal-stretch: 1;
                        vertical-alignment: center;
                    }
                    Rectangle {
                        width: 44px;
                        height: 20px;
                        border-radius: Theme.radius-sm;
                        background: clear-ta.has-hover ? Theme.bg-hover : transparent;
                        clear-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.clear-transfers(); }
                        }
                        Text {
                            text: @tr("Clear");
                            color: Theme.text-muted;
                            font-size: Theme.fs-xs;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                Flickable {
                    vertical-stretch: 1;
                    viewport-width: self.width;
                    viewport-height: max(self.height, transfer-col.preferred-height);
                    transfer-col := VerticalLayout {
                        alignment: start;
                        spacing: 4px;

                        if root.transfers.length == 0 : Text {
                            text: @tr("No transfers yet");
                            color: Theme.text-muted;
                            font-size: Theme.fs-xs;
                        }

                        for item in root.transfers : Rectangle {
                            height: 32px;
                            border-radius: Theme.radius-sm;
                            background: Theme.bg-root;
                            VerticalLayout {
                                padding-left: 8px;
                                padding-right: 8px;
                                padding-top: 4px;
                                padding-bottom: 4px;
                                spacing: 3px;
                                HorizontalLayout {
                                    spacing: 4px;
                                    Text {
                                        text: (item.is-upload ? "↑ " : "↓ ") + item.name;
                                        color: Theme.text-primary;
                                        font-size: Theme.fs-xs;
                                        horizontal-stretch: 1;
                                        overflow: elide;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: item.detail;
                                        color: item.state == 2 ? Theme.danger : item.state == 1 ? Theme.success : Theme.text-muted;
                                        font-size: Theme.fs-xs;
                                        vertical-alignment: center;
                                    }
                                }
                                Rectangle {
                                    height: 4px;
                                    border-radius: 2px;
                                    background: Theme.bg-elevated;
                                    Rectangle {
                                        x: 0;
                                        y: 0;
                                        height: parent.height;
                                        width: parent.width * clamp(item.percent, 0.0, 1.0);
                                        border-radius: 2px;
                                        background: item.state == 2 ? Theme.danger : item.state == 1 ? Theme.success : Theme.accent;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
