import { Theme } from "theme.slint";
import { SftpPanel, SftpEntry, SftpTreeNode } from "sftp_panel.slint";
import { TunnelPanel, TunnelRuleInfo } from "tunnel_panel.slint";

component PanelTab inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    callback clicked();

    height: 28px;
    min-width: 72px;
    border-radius: Theme.radius-sm;
    background: active ? Theme.bg-active : (touch.has-hover ? Theme.bg-hover : transparent);

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    Text {
        text: root.label;
        color: root.active ? Theme.text-primary : Theme.text-secondary;
        font-size: Theme.fs-sm;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export component BottomPanel inherits Rectangle {
    in property <string> active-tab: "files";
    in property <string> current-path: "/";
    in property <[SftpEntry]> entries;
    in property <string> status: "";
    in property <bool> loading: false;
    in property <[SftpTreeNode]> tree-nodes: [];
    in property <[TunnelRuleInfo]> tunnel-rules: [];

    callback select-tab(string);
    callback navigate(string);
    callback download(string);
    callback upload-clicked(string);
    callback refresh(string);
    callback tree-expand(string);
    callback delete(string);
    callback view(string);
    callback edit(string);
    callback tunnel-add-rule();
    callback tunnel-create-rule(string, string, string, string, string);
    callback tunnel-update-rule(string, string, string, string, string, string);
    callback tunnel-toggle-rule(string, bool);
    callback tunnel-suspend-rule(string);
    callback tunnel-resume-rule(string);
    callback tunnel-delete-rule(string);

    background: Theme.bg-panel;

    VerticalLayout {
        spacing: 0;

        Rectangle {
            height: 34px;
            background: Theme.bg-panel-alt;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                padding-top: 3px;
                padding-bottom: 3px;
                spacing: 4px;

                PanelTab {
                    label: @tr("Files");
                    active: root.active-tab == "files";
                    clicked => { root.select-tab("files"); }
                }

                PanelTab {
                    label: @tr("Tunnels");
                    active: root.active-tab == "tunnels";
                    clicked => { root.select-tab("tunnels"); }
                }

                Rectangle { horizontal-stretch: 1; }
            }
        }

        if root.active-tab == "files" : SftpPanel {
            vertical-stretch: 1;
            current-path: root.current-path;
            entries: root.entries;
            status: root.status;
            loading: root.loading;
            tree-nodes: root.tree-nodes;
            navigate(path) => { root.navigate(path); }
            download(path) => { root.download(path); }
            upload-clicked(dir) => { root.upload-clicked(dir); }
            refresh(path) => { root.refresh(path); }
            tree-expand(path) => { root.tree-expand(path); }
            delete(path) => { root.delete(path); }
            view(path) => { root.view(path); }
            edit(path) => { root.edit(path); }
        }

        if root.active-tab == "tunnels" : TunnelPanel {
            vertical-stretch: 1;
            rules: root.tunnel-rules;
            add-rule => { root.tunnel-add-rule(); }
            create-rule(name, lh, lp, rh, rp) => {
                root.tunnel-create-rule(name, lh, lp, rh, rp);
            }
            update-rule(id, name, lh, lp, rh, rp) => {
                root.tunnel-update-rule(id, name, lh, lp, rh, rp);
            }
            toggle-rule(id, enabled) => { root.tunnel-toggle-rule(id, enabled); }
            suspend-rule(id) => { root.tunnel-suspend-rule(id); }
            resume-rule(id) => { root.tunnel-resume-rule(id); }
            delete-rule(id) => { root.tunnel-delete-rule(id); }
        }
    }
}
