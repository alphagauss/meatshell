import { Theme } from "theme.slint";

component ActionButton inherits Rectangle {
    in property <string> icon;
    in property <string> tooltip;
    callback clicked();
    callback tooltip-show(string, length, length);
    callback tooltip-hide();

    width: 28px;
    height: 28px;
    border-radius: Theme.radius-sm;
    background: touch.has-hover ? Theme.bg-hover : transparent;

    Text {
        text: root.icon;
        font-family: "Material Icons";
        color: touch.has-hover ? Theme.text-primary : Theme.text-secondary;
        font-size: 18px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.tooltip-hide();
            root.clicked();
        }
        changed has-hover => {
            if self.has-hover {
                root.tooltip-show(root.tooltip, root.absolute-position.x, root.absolute-position.y + root.height + 2px);
            } else {
                root.tooltip-hide();
            }
        }
    }
}

export component TopActionBar inherits Rectangle {
    in property <bool> sidebar-visible: true;
    in property <bool> bottom-panel-visible: true;

    callback toggle-sidebar();
    callback toggle-bottom-panel();
    callback disconnect-active-tab();
    callback reconnect-active-tab();
    callback open-transfer-window();
    callback tooltip-show(string, length, length);
    callback tooltip-hide();

    height: 34px;
    background: Theme.bg-panel;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 4px;
        alignment: start;

        ActionButton {
            icon: root.sidebar-visible ? "\u{E5D2}" : "\u{E5D2}";
            tooltip: @tr("Toggle sidebar");
            clicked => { root.toggle-sidebar(); }
            tooltip-show(text, x, y) => { root.tooltip-show(text, x, y); }
            tooltip-hide => { root.tooltip-hide(); }
        }

        ActionButton {
            icon: root.bottom-panel-visible ? "\u{E5DB}" : "\u{E5D8}";
            tooltip: @tr("Toggle file panel");
            clicked => { root.toggle-bottom-panel(); }
            tooltip-show(text, x, y) => { root.tooltip-show(text, x, y); }
            tooltip-hide => { root.tooltip-hide(); }
        }

        Rectangle { width: 1px; height: 20px; background: Theme.border-subtle; }

        ActionButton {
            icon: "\u{E8AC}";
            tooltip: @tr("Disconnect");
            clicked => { root.disconnect-active-tab(); }
            tooltip-show(text, x, y) => { root.tooltip-show(text, x, y); }
            tooltip-hide => { root.tooltip-hide(); }
        }

        ActionButton {
            icon: "\u{E5D5}";
            tooltip: @tr("Reconnect");
            clicked => { root.reconnect-active-tab(); }
            tooltip-show(text, x, y) => { root.tooltip-show(text, x, y); }
            tooltip-hide => { root.tooltip-hide(); }
        }

        ActionButton {
            icon: "\u{E2C6}";
            tooltip: @tr("New transfer window");
            clicked => { root.open-transfer-window(); }
            tooltip-show(text, x, y) => { root.tooltip-show(text, x, y); }
            tooltip-hide => { root.tooltip-hide(); }
        }

        Rectangle { horizontal-stretch: 1; }
    }
}
