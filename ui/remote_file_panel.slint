import { Theme } from "theme.slint";
import { ScrollView } from "std-widgets.slint";
import { SftpEntry } from "sftp_panel.slint";

component FileMenuItem inherits Rectangle {
    in property <string> label;
    callback clicked();
    height: 26px;
    border-radius: Theme.radius-sm;
    background: ta.has-hover ? Theme.bg-hover : transparent;
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
    Text {
        x: 10px;
        text: root.label;
        color: Theme.text-primary;
        font-size: Theme.fs-sm;
        vertical-alignment: center;
        height: parent.height;
    }
}

export component RemoteFilePanel inherits Rectangle {
    in property <string> current-path;
    in property <[SftpEntry]> entries;
    in property <string> status;
    in property <bool> loading;
    property <bool> rename-open;
    property <string> rename-path;
    property <string> rename-name;

    callback navigate(string);
    callback refresh();
    callback download(string);
    callback open(string);
    callback edit(string);
    callback rename(string, string);

    background: Theme.bg-panel;

    VerticalLayout {
        spacing: 0;

        Rectangle {
            height: 30px;
            background: Theme.bg-panel-alt;
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 6px;
                spacing: 4px;
                Text {
                    text: root.current-path;
                    color: Theme.text-primary;
                    font-size: Theme.fs-sm;
                    horizontal-stretch: 1;
                    overflow: elide;
                    vertical-alignment: center;
                }
                Rectangle {
                    width: 24px;
                    height: 22px;
                    border-radius: Theme.radius-sm;
                    background: up-ta.has-hover ? Theme.bg-hover : transparent;
                    up-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.navigate(".."); }
                    }
                    Text {
                        text: "\u{E5D8}";
                        font-family: "Material Icons";
                        color: Theme.text-secondary;
                        font-size: Theme.fs-sm;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
                Rectangle {
                    width: 24px;
                    height: 22px;
                    border-radius: Theme.radius-sm;
                    background: ref-ta.has-hover ? Theme.bg-hover : transparent;
                    ref-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.refresh(); }
                    }
                    Text {
                        text: "\u{E5D5}";
                        font-family: "Material Icons";
                        color: Theme.text-secondary;
                        font-size: Theme.fs-sm;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Rectangle {
            height: 22px;
            background: Theme.bg-root;
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 8px;
                Text { text: @tr("Remote"); color: Theme.text-muted; font-size: Theme.fs-xs; horizontal-stretch: 1; vertical-alignment: center; }
                Text { text: @tr("Size"); color: Theme.text-muted; font-size: Theme.fs-xs; width: 72px; horizontal-alignment: right; vertical-alignment: center; }
                Rectangle { width: 28px; }
            }
        }

        ScrollView {
            vertical-stretch: 1;
            VerticalLayout {
                spacing: 0;
                if root.loading : Rectangle {
                    height: 42px;
                    Text {
                        text: @tr("Loading...");
                        color: Theme.text-muted;
                        font-size: Theme.fs-sm;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
                if !root.loading && root.entries.length == 0 : Rectangle {
                    height: 42px;
                    Text {
                        text: @tr("Empty directory");
                        color: Theme.text-muted;
                        font-size: Theme.fs-sm;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
                for entry[i] in root.entries : row := Rectangle {
                    height: 26px;
                    background: row-ta.has-hover ? #4a90e225 : (mod(i, 2) == 0 ? transparent : #ffffff08);
                    property <length> mx;
                    property <length> my;
                    row-ta := TouchArea {
                        mouse-cursor: pointer;
                        double-clicked => {
                            if (entry.is-dir) {
                                root.navigate(entry.full-path);
                            } else {
                                root.download(entry.full-path);
                            }
                        }
                        pointer-event(ev) => {
                            if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.right) {
                                row.mx = self.mouse-x;
                                row.my = self.mouse-y;
                                row-menu.show();
                            }
                        }
                    }
                    row-menu := PopupWindow {
                        x: row.mx;
                        y: row.my;
                        width: 112px;
                        height: (entry.is-dir ? 1 : 4) * 27px + 8px;
                        Rectangle {
                            background: Theme.bg-panel;
                            border-radius: Theme.radius-sm;
                            border-width: 1px;
                            border-color: Theme.border-strong;
                            drop-shadow-blur: 12px;
                            drop-shadow-color: #00000060;
                            VerticalLayout {
                                padding: 4px;
                                spacing: 1px;
                                if !entry.is-dir : FileMenuItem {
                                    label: @tr("Transfer");
                                    clicked => { root.download(entry.full-path); }
                                }
                                if !entry.is-dir : FileMenuItem {
                                    label: @tr("Open");
                                    clicked => { root.open(entry.full-path); }
                                }
                                if !entry.is-dir : FileMenuItem {
                                    label: @tr("Edit");
                                    clicked => { root.edit(entry.full-path); }
                                }
                                FileMenuItem {
                                    label: @tr("Rename");
                                    clicked => {
                                        root.rename-path = entry.full-path;
                                        root.rename-name = entry.name;
                                        root.rename-open = true;
                                    }
                                }
                            }
                        }
                    }
                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 6px;
                        spacing: 6px;
                        Text {
                            text: entry.is-dir ? "\u{E2C7}" : "\u{E24D}";
                            font-family: "Material Icons";
                            color: entry.is-dir ? Theme.accent : Theme.text-secondary;
                            font-size: Theme.fs-sm;
                            width: 16px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        Text {
                            text: entry.name;
                            color: entry.is-dir ? Theme.accent : Theme.text-primary;
                            font-size: Theme.fs-sm;
                            horizontal-stretch: 1;
                            overflow: elide;
                            vertical-alignment: center;
                        }
                        Text {
                            text: entry.is-dir ? "" : entry.size;
                            color: Theme.text-secondary;
                            font-size: Theme.fs-xs;
                            width: 72px;
                            horizontal-alignment: right;
                            vertical-alignment: center;
                        }
                        Rectangle {
                            width: 28px;
                            height: 22px;
                            border-radius: Theme.radius-sm;
                            background: !entry.is-dir && dl-ta.has-hover ? Theme.bg-hover : transparent;
                            dl-ta := TouchArea {
                                enabled: !entry.is-dir;
                                mouse-cursor: pointer;
                                clicked => { root.download(entry.full-path); }
                            }
                            Text {
                                visible: !entry.is-dir;
                                text: "\u{E2C4}";
                                font-family: "Material Icons";
                                color: Theme.text-secondary;
                                font-size: Theme.fs-sm;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 20px;
            background: Theme.bg-panel-alt;
            Text {
                x: 8px;
                width: parent.width - 16px;
                height: parent.height;
                text: root.status;
                color: Theme.text-muted;
                font-size: Theme.fs-xs;
                overflow: elide;
                vertical-alignment: center;
            }
        }
    }

    if root.rename-open : Rectangle {
        width: root.width > 296px ? 280px : root.width - 16px;
        height: 92px;
        x: (root.width - self.width) / 2;
        y: 52px;
        border-radius: Theme.radius-md;
        border-width: 1px;
        border-color: Theme.border-strong;
        background: Theme.bg-panel;
        drop-shadow-blur: 14px;
        drop-shadow-color: #00000070;

        VerticalLayout {
            padding: 10px;
            spacing: 8px;
            Text {
                text: @tr("Rename");
                color: Theme.text-primary;
                font-size: Theme.fs-sm;
                font-weight: 600;
            }
            Rectangle {
                height: 28px;
                border-radius: Theme.radius-sm;
                border-width: 1px;
                border-color: Theme.border-subtle;
                background: Theme.bg-root;
                TextInput {
                    x: 8px;
                    width: parent.width - 16px;
                    height: parent.height;
                    text <=> root.rename-name;
                    color: Theme.text-primary;
                    font-size: Theme.fs-sm;
                    single-line: true;
                    vertical-alignment: center;
                }
            }
            HorizontalLayout {
                spacing: 8px;
                alignment: end;
                Rectangle {
                    width: 60px;
                    height: 24px;
                    border-radius: Theme.radius-sm;
                    background: cancel-ta.has-hover ? Theme.bg-hover : Theme.bg-elevated;
                    cancel-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.rename-open = false; }
                    }
                    Text { text: @tr("Cancel"); color: Theme.text-primary; font-size: Theme.fs-xs; horizontal-alignment: center; vertical-alignment: center; }
                }
                Rectangle {
                    width: 60px;
                    height: 24px;
                    border-radius: Theme.radius-sm;
                    background: ok-ta.has-hover ? Theme.accent-hover : Theme.accent;
                    ok-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.rename(root.rename-path, root.rename-name);
                            root.rename-open = false;
                        }
                    }
                    Text { text: @tr("OK"); color: white; font-size: Theme.fs-xs; horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }
    }
}
